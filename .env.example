# Environment Variables for Cloud Deployment
# Copy this file to .env for local testing
# Add these variables in Render dashboard for production

# Flask Secret Key (change this to a random string)
SECRET_KEY=your-super-secret-random-key-change-this-in-production

# Admin Credentials
ADMIN_USERNAME=DCME
ADMIN_PASSWORD=DCME155

# Port (Render sets this automatically)
PORT=5000
